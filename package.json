{
  "name": "cav-san-benito",
  "version": "1.0.0",
  "description": "Centro de Atención al Vecino — Municipalidad de San Benito",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "seed": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" tsx src/seed/seedReclamos.ts",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "bun run test:int && bun run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "skills": "npx skills@latest update -p",
    "ncu": "npx npm-check-updates@latest -i"
  },
  "dependencies": {
    "@payloadcms/db-mongodb": "3.85.1",
    "@payloadcms/next": "3.85.1",
    "@payloadcms/richtext-lexical": "3.85.1",
    "@payloadcms/sdk": "3.85.1",
    "@payloadcms/storage-s3": "3.85.1",
    "@payloadcms/ui": "3.85.1",
    "@tabler/icons-react": "3.44.0",
    "@tailwindcss/postcss": "4.3.1",
    "@tanstack/react-table": "8.21.3",
    "@types/leaflet": "1.9.21",
    "bson": "6.10.3",
    "cross-env": "10.1.0",
    "daisyui": "5.5.23",
    "dotenv": "17.4.2",
    "graphql": "17.0.1",
    "leaflet": "1.9.4",
    "next": "16.2.9",
    "payload": "3.85.1",
    "postcss": "8.5.15",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-leaflet": "5.0.0",
    "sharp": "0.35.2",
    "tailwindcss": "4.3.1"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "10.5.0",
    "eslint-config-next": "16.2.9",
    "jsdom": "29.1.1",
    "prettier": "3.8.4",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.9"
  },
  "trustedDependencies": [
    "sharp",
    "esbuild",
    "unrs-resolver"
  ]
}
